{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/products(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/product/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
